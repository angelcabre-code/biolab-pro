{
  "name": "biolab",
  "private": true,
  "version": "1.0.6",
  "type": "module",
  "main": "dist-electron/main.cjs",
  "scripts": {
    "dev": "vite",
    "build": "vue-tsc -b && vite build",
    "preview": "vite preview",
    "app:dev": "vite",
    "app:build": "vue-tsc -b && vite build && electron-builder",
    "mobile:build": "vue-tsc -b && vite build && npx cap sync android",
    "mobile:open": "npx cap open android"
  },
  "dependencies": {
    "@capacitor/android": "^8.2.0",
    "@capacitor/cli": "^8.2.0",
    "@capacitor/core": "^8.2.0",
    "@capacitor/device": "^8.0.1",
    "@capacitor/filesystem": "^8.1.2",
    "@capacitor/preferences": "^8.0.1",
    "chart.js": "^4.5.1",
    "clsx": "^2.1.1",
    "dexie": "^3.2.4",
    "firebase": "^12.11.0",
    "lucide-vue-next": "^0.577.0",
    "node-machine-id": "^1.1.12",
    "pinia": "^3.0.4",
    "tailwind-merge": "^3.5.0",
    "vue": "^3.5.30",
    "vue-chartjs": "^5.3.3",
    "vue-router": "^4.6.4"
  },
  "devDependencies": {
    "@capacitor/assets": "^3.0.5",
    "@tailwindcss/vite": "^4.2.2",
    "@types/node": "^24.12.0",
    "@vitejs/plugin-vue": "^6.0.5",
    "@vue/tsconfig": "^0.9.0",
    "autoprefixer": "^10.4.27",
    "crypto-js": "^4.2.0",
    "electron": "^41.0.3",
    "electron-builder": "^26.8.1",
    "esbuild": "^0.27.4",
    "postcss": "^8.5.8",
    "tailwindcss": "^4.2.2",
    "typescript": "~5.9.3",
    "vite": "^8.0.1",
    "vite-plugin-electron": "^0.29.1",
    "vite-plugin-electron-renderer": "^0.14.6",
    "vue-tsc": "^3.2.5"
  },
  "build": {
    "appId": "com.sinergia.biolabpro",
    "productName": "Biolab Pro",
    "directories": {
      "output": "release"
    },
    "files": [
      "dist",
      "dist-electron"
    ],
    "win": {
      "icon": "public/logo_sinergia.png",
      "target": [
        "nsis",
        "portable"
      ]
    },
    "portable": {
      "artifactName": "${productName} Portable ${version}.${ext}"
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true,
      "installerHeaderIcon": "public/logo_sinergia.png",
      "installerHeader": "build/installerHeader.png",
      "installerSidebar": "build/installerSidebar.png",
      "uninstallerSidebar": "build/installerSidebar.png",
      "license": "license.txt"
    }
  }
}
